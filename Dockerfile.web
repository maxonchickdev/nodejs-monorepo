FROM node:22.22.0-bookworm-slim AS builder

WORKDIR /app

RUN npm install -g npm@11.6.2

COPY package.json package-lock.json tsconfig.base.json ./
COPY packages/shared ./packages/shared
COPY apps/web ./apps/web

ARG TARGETARCH

RUN npm ci \
	&& case "$TARGETARCH" in \
		amd64) ROLLUP_NATIVE=@rollup/rollup-linux-x64-gnu; SWC_NATIVE=@swc/core-linux-x64-gnu ;; \
		arm64) ROLLUP_NATIVE=@rollup/rollup-linux-arm64-gnu; SWC_NATIVE=@swc/core-linux-arm64-gnu ;; \
		*) echo "Unsupported TARGETARCH=$TARGETARCH for Rollup/SWC native bindings" >&2; exit 1 ;; \
	esac \
	&& npm install --no-save --no-audit --no-fund "$ROLLUP_NATIVE" "$SWC_NATIVE" \
	&& npm run build -w @nodejs-monorepo/web

FROM node:22.22.0-bookworm-slim AS runner

WORKDIR /app

RUN npm install -g serve@14

COPY --from=builder /app/apps/web/dist ./dist

EXPOSE 3000

CMD ["serve", "-s", "dist", "-l", "3000"]
