#
# Environment
#
NODE_ENV=example-node-env
#
# Application
#
APP_PORT=0000
APP_REQUEST_TIMEOUT=0000
APP_NAME='example app name'
APP_DESCRIPTION='example app description'
#
# Postgres
#
POSTGRES_URL=example-postgres-url
POSTGRES_HOST=example-postgres-host
POSTGRES_PORT=00000
POSTGRES_USER=example-postgres-user
POSTGRES_PASSWORD=example-postgres-pass
POSTGRES_DB=example-postgres-db
#
# Kafka
#
KAFKA_NODE_ID=0
KAFKA_PORT=0000
KAFKA_CONTROLLER_PORT=0000
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=0
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=0
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=0
KAFKA_GROUP_INITIAL_REBALANCE_DELAY_MS=0
KAFKA_NUM_PARTITIONS=0
#
# Kafka UI
#
KAFKA_UI_PORT=0000
KAFKA_CLUSTERS_0_NAME=example-kafka-cluster-0-name
#
# Redis
#
REDIS_URL=example-redis-url
REDIS_PORT=0000
REDIS_HOST=example-redis-host
REDIS_DATABASES=0
REDIS_PASSWORD=000
#
# Redis UI
#
RI_PORT=0000
RI_DISABLE_ENCRYPTION=0
#
# I18N
#
I18N_FALLBACK_LANGUAGE=example-i18n-fallback-language
#
# JWT
#
JWT_SECRET=example-jwt-secret
JWT_EXPIRES_IN=0000
#
# Rate limiting
#
THROTTLE_TTL=00000
THROTTLE_LIMIT=000
