# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
indent_style = tab
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = false
insert_final_newline = true

# YAML, SQL, Prisma, HTML conventionally use spaces
[*.{yml,yaml}]
indent_style = space

[*.sql]
indent_style = space

[*.prisma]
indent_style = space

[*.html]
indent_style = space
