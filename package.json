{
	"author": "maxondev",
	"description": "NodeJS Monorepo",
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@commitlint/cli": "^20.3.1",
		"@commitlint/config-conventional": "^20.3.1",
		"@commitlint/types": "^20.5.0",
		"@ls-lint/ls-lint": "^2.3.1",
		"concurrently": "^9.2.1",
		"knip": "^5.82.1",
		"lint-staged": "^16.3.3",
		"simple-git-hooks": "^2.13.1",
		"typescript": "^6.0.2"
	},
	"keywords": [],
	"license": "ISC",
	"name": "nodejs-monorepo",
	"overrides": {
		"@nestjs/common": "^11.1.12",
		"@nestjs/core": "^11.1.12",
		"@nestjs/platform-express": "^11.1.12",
		"rxjs": "^7.8.2"
	},
	"engines": {
		"node": "22.22.0",
		"npm": "10.9.4"
	},
	"private": true,
	"repository": {
		"type": "git",
		"url": "git@github.com-maxondev-personal:maxonchickdev/nodejs-monorepo.git"
	},
	"scripts": {
		"docker:compose:down": "docker compose --env-file .env -f docker-compose.yml down -v",
		"docker:compose:start": "docker compose --env-file .env -f docker-compose.yml start",
		"docker:compose:stop": "docker compose --env-file .env -f docker-compose.yml stop -t 10",
		"docker:compose:up": "docker compose --env-file .env -f docker-compose.yml up -d --no-color --timestamps --wait --wait-timeout 20",
		"docker:build:web": "docker build -f Dockerfile.web -t nodejs-monorepo-web .",
		"docker:build:backend": "docker build -f Dockerfile.backend -t nodejs-monorepo-backend .",
		"hooks:init": "simple-git-hooks",
		"hooks:precommit": "lint-staged",
		"hooks:prepush": "concurrently 'npm run build -w apps/web' 'npm run build -w apps/backend' 'npm run build -w packages/shared'",
		"lint:check": "biome lint",
		"lint:fix": "biome lint --write",
		"lint:format:check": "biome format",
		"lint:format:fix": "biome format --write",
		"lint:clean:check": "knip",
		"lint:filesystem:check": "ls-lint"
	},
	"type": "module",
	"version": "1.0.0",
	"workspaces": [
		"packages/shared",
		"apps/web",
		"apps/backend"
	]
}
